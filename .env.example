# Public site URL (canonical, OG, sitemap için kullanılır)
NEXT_PUBLIC_SITE_URL=https://gunerdev.com

# Node ortamı (geliştirmede 'development', üretimde 'production')
NODE_ENV=production

# Telegram bildirim entegrasyonu (iletişim formu doldurulunca admin'e mesaj atar)
#
# Kurulum:
#   1) Telegram'da @BotFather'a /newbot, bot adı + username belirle.
#      BotFather sana "123456789:ABC-DEF1234..." formatında bir token verir.
#   2) Yeni botunla bir mesaj at (örn. /start). Bu adım önemli — bot
#      güncelleme alabilmek için en az bir interaction'a ihtiyaç duyar.
#   3) Tarayıcıda şu URL'i aç:
#        https://api.telegram.org/bot<TOKEN>/getUpdates
#      Dönen JSON'da "chat":{"id":...} sayısını al — bu senin chat ID'n.
#   4) Aşağıdaki iki değeri doldur:
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
